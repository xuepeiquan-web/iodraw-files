        <mxCell id="step1" value="&lt;div style=&quot;font-weight: 700;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;01 先梳清CSV变更和基线场景&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(51, 65, 85); margin-top: 10px;&quot;&gt;&lt;font size=&quot;3&quot; style=&quot;&quot;&gt;先弄清组织关系怎么变，再搭一套能跑通主链路的基线数据。&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#a7f3d0;strokeWidth=2;arcSize=18;spacing=12;" parent="1" vertex="1">
          <mxGeometry x="105" y="220" width="590" height="80" as="geometry" />
        </mxCell>
